# ===== App =====
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3001

# ===== Database =====
DATABASE_URL=postgres://agc:agc_dev_password@localhost:5432/agc_crm
DATABASE_POOL_MAX=20

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== JWT =====
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_64_BYTES_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_64_BYTES_RANDOM
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ===== Auth =====
BCRYPT_COST=12
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# ===== Metals.dev =====
METALS_API_KEY=H2UIFS5JPUJYYPNVT67V910NVT67V
METALS_API_URL=https://api.metals.dev/v1/latest
METALS_CACHE_TTL_SEC=30

# ===== Email =====
# Leave SMTP_HOST blank to use the dev log-only transport.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AGC CRM <noreply@example.com>"

# ===== SMS (Twilio) =====
# Leave TWILIO_ACCOUNT_SID blank to use the dev log-only transport.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ===== Feature flags =====
ENABLE_2FA=false
ENABLE_SIGNUP=true
