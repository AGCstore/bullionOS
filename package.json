{
  "name": "agc-crm",
  "private": true,
  "version": "0.1.0",
  "description": "AGC CRM + Trading + Inventory system with client portal",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @agc/api run db:migrate",
    "db:rollback": "pnpm --filter @agc/api run db:rollback",
    "db:seed": "pnpm --filter @agc/api run db:seed",
    "db:seed:trading": "pnpm --filter @agc/api run db:seed:trading",
    "api:dev": "pnpm --filter @agc/api run dev",
    "web:dev": "pnpm --filter @agc/web run dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
